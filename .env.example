NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# SQLite data directory. Use an absolute path in production.
DATA_DIR=/var/lib/api-forge

# Optional: overrides DATA_DIR/mock-data.db when set.
# SQLITE_DB_PATH=/var/lib/api-forge/mock-data.db

# AI Chat uses model profiles configured in the UI and stored in SQLite.
# No fixed API key is required at process startup.
